{
  "name": "wildfire",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run --filter '*' build",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "clean": "rm -rf ./dist",
    "dev": "bun run --filter '*' dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "lefthook": "^1.11.14"
  },
  "packageManager": "bun@1.2.17"
}
